{
  "name": "@karn_lat/protocol-sdk-solana",
  "version": "0.1.0-alpha.1",
  "description": "TypeScript SDK for Karn Protocol on Solana — thin clients for Valocracy, Governor and Treasury programs",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "require": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    }
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p ./tsconfig.build.json",
    "test": "ts-mocha -p ./tsconfig.json -t 10000 \"tests/**/*.spec.ts\"",
    "lint": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/web3.js": "^1.95.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "@types/node": "^25.6.0",
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.7.3"
  }
}
