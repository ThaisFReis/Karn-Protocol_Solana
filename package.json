{
  "name": "karn-protocol-solana",
  "version": "0.1.0",
  "description": "Karn Protocol — Solana/Anchor implementation",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "anchor build",
    "test": "anchor build && npx ts-mocha -p ./tsconfig.json -t 60000 \"tests/**/*.spec.ts\"",
    "test:rust": "cargo test --workspace",
    "test:full": "anchor test",
    "deploy:devnet": "anchor deploy --provider.cluster devnet",
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1"
  },
  "devDependencies": {
    "@solana/spl-token": "^0.4.14",
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "@types/node": "^25.6.0",
    "anchor-bankrun": "^0.5.0",
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "solana-bankrun": "^0.4.0",
    "ts-mocha": "^10.0.0",
    "tweetnacl": "^1.0.3",
    "typescript": "^5.7.3"
  }
}
